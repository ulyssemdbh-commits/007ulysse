# =============================================================================
# 007ulysse / Ulysse AI — Environment Variables
# Copy to .env and fill in values before running
# =============================================================================

# --- Database (REQUIRED in production) ---
DATABASE_URL=postgresql://user:password@localhost:5432/ulysse

# --- Security (REQUIRED in production) ---
JWT_SECRET=                     # Min 32 chars, used for JWT signing
SESSION_SECRET=                 # Session cookie signing secret
OWNER_CODE_PIN=                 # PIN for sensitive owner operations (min 4 chars)
ENCRYPTION_KEY=                 # AES encryption key for sensitive data
SECRETS_ENCRYPTION_KEY=         # DevMax secrets encryption

# --- Server ---
PORT=5000
NODE_ENV=development            # development | production | test
BASE_URL=http://localhost:5000

# --- AI Services ---
OPENAI_API_KEY=                 # Or use AI_INTEGRATIONS_OPENAI_API_KEY
AI_INTEGRATIONS_OPENAI_API_KEY=
AI_INTEGRATIONS_OPENAI_BASE_URL=
PERPLEXITY_API_KEY=
FIRECRAWL_API_KEY=

# --- Google Services ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# --- GitHub ---
GITHUB_TOKEN=
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
MAURICE_GITHUB_PAT=

# --- Discord ---
DISCORD_BOT_TOKEN=
DISCORD_SHOPPING_CHANNEL=

# --- DevMax ---
DEVMAX_ADMIN_PIN=

# --- SUGU / Restaurant ---
COBA_API_KEY=

# --- Social / Commax ---
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
META_APP_ID=
META_APP_SECRET=

# --- Voice / Auth ---
TALKING_PINS_B64=               # Base64-encoded PIN list for voice auth
ALFRED_PASSWORD=                # Password for Alfred (external) users

# --- External Services ---
SPEAKER_SERVICE_URL=http://localhost:5001
REDIS_URL=                      # Optional: Redis for distributed sessions

# --- Deployment ---
ALLOWED_ORIGINS=                # Comma-separated extra CORS origins
ALLOWED_FRAME_ORIGINS=          # Comma-separated frame ancestor origins
CLUSTER_WORKERS=0               # 0 = auto (min(cpus, 8))
